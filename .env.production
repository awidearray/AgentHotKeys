# Production Environment Configuration
# Replace these values with your actual production credentials

# Skip environment validation for deployment builds
SKIP_ENV_VALIDATION=true

# Authentication
NEXTAUTH_URL=${DEPLOY_URL}
NEXTAUTH_SECRET=${NEXTAUTH_SECRET}

# Database - Supabase
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Web3 Configuration
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=${WALLET_CONNECT_PROJECT_ID}
NEXT_PUBLIC_ALCHEMY_ID=${ALCHEMY_API_KEY}

# Stripe
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=${STRIPE_PAYMENT_LINK}

# Platform Configuration
SITE_URL=${DEPLOY_URL}
ADMIN_SECRET_TOKEN=${ADMIN_SECRET_TOKEN}

# Platform Wallets
PLATFORM_ETH_WALLET=${PLATFORM_ETH_WALLET}
PLATFORM_MATIC_WALLET=${PLATFORM_MATIC_WALLET}
PLATFORM_USDC_WALLET=${PLATFORM_USDC_WALLET}

# Email Service (Brevo)
BREVO_API_KEY=${BREVO_API_KEY}
BREVO_LIST_ID=${BREVO_LIST_ID}
BREVO_SENDER_EMAIL=${BREVO_SENDER_EMAIL}
BREVO_SENDER_NAME=${BREVO_SENDER_NAME}