{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "agenthotkeys",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // KV for download tokens (create with: wrangler kv namespace create PURCHASE_TOKENS)
  // "kv_namespaces": [
  //   { "binding": "PURCHASE_TOKENS", "id": "<KV_NAMESPACE_ID>" }
  // ],
  // R2 for private PDF storage (create with: wrangler r2 bucket create agenthotkeys-pdfs)
  // "r2_buckets": [
  //   { "binding": "PDF_BUCKET", "bucket_name": "agenthotkeys-pdfs" }
  // ],
  "vars": {
    "NEXT_PUBLIC_STRIPE_PAYMENT_LINK": "https://buy.stripe.com/00wcN51Qx0iV1aSeva57W01",
    "SITE_URL": "https://agenthotkeys.com"
  }
  // Secrets (set via: wrangler secret put <NAME>):
  // STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, BREVO_API_KEY, BREVO_LIST_ID, BREVO_PURCHASERS_LIST_ID
}
