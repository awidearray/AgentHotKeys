# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# GitHub (OAuth + Webhook)
# OAuth: Developer Settings → OAuth Apps → Client ID/Secret
# Webhook: GitHub App → Webhook URL = https://hotkeys.ai/api/github/webhook
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Database - Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (existing)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Web3
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-wallet-connect-id
NEXT_PUBLIC_ALCHEMY_ID=your-alchemy-id

# Email - Brevo
BREVO_API_KEY=xkeysib-your-key
BREVO_SENDER_EMAIL=hello@hotkeys.ai
BREVO_SENDER_NAME=HotKeys.ai
# Run npm run brevo:setup to create lists and get IDs
BREVO_LIST_ID=6
BREVO_PURCHASERS_LIST_ID=7

# Platform Settings
PLATFORM_FEE_MONTHLY=2
PLATFORM_COMMISSION_PERCENT=10